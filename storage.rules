rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email in ['19980531mg@gmail.com', 'forpin1014@gmail.com'];
    }

    // Product photos: anyone signed in (including anonymous customer sessions) can
    // view, but only the admin can upload/replace/delete.
    match /products/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
